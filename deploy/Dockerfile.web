# Build the SPA, then bake it into a Caddy image that serves it and proxies /api.
# Build context is the repo root (see docker-compose.prod.yml).
FROM node:22-slim AS build
WORKDIR /app
COPY . .
RUN npm install && npm run build -w @legiapp/web

FROM caddy:2-alpine
COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/apps/web/dist /srv
EXPOSE 80 443
