# ─────────────────────────────────────────────────────────────────────────────
# LegiApp environment. Copy to `.env` and adjust as needed.
# ─────────────────────────────────────────────────────────────────────────────

# Database — portable local Postgres started by `npm run db:start` listens here.
# (When running via docker-compose instead, point this at the compose service.)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/legiapp
PGPORT=5433

# API
API_PORT=4000
# Token required by POST /api/ingest/refresh — set to a long random string.
INGEST_REFRESH_TOKEN=change-me-to-a-long-random-string
# Comma-separated allowed browser origins for CORS.
WEB_ORIGIN=http://localhost:5173,http://localhost:4173
# API DB connection pool size.
PGPOOL_MAX=16
# Shared access code that gates the whole site (the org shares one code). Set a
# strong value in production — anyone with this code can view the tool.
ACCESS_CODE=nova-ukraine-dev

# Web (Vite) — base URL of the API
VITE_API_BASE_URL=http://localhost:4000

# ── Free API keys (optional; cross-source reconciliation only) ──
# Register free at openstates.org and legiscan.com.
OPENSTATES_API_KEY=
LEGISCAN_API_KEY=

# Ingestion
# Which PUBINFO archive to seed from. "2025" = the 2025-2026 session annual file (~950MB).
# Use a weekday name (e.g. "Tue") to pull the smaller weekly file for quick dev iterations.
PUBINFO_ARCHIVE=2025
# Polite delay (ms) between chamber-site scrape requests
SCRAPE_DELAY_MS=800
