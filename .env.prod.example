# ─────────────────────────────────────────────────────────────────────────────
# Production env for docker-compose.prod.yml.  Copy to `.env.prod` and edit.
#   cp .env.prod.example .env.prod
# Never commit .env.prod — it holds your real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Public address Caddy answers on. Use your DOMAIN for automatic HTTPS:
#   SITE_ADDRESS=legiapp.novaukraine.org
# Point that domain's DNS A record at this server's IP first. For a quick
# IP-only / local test without TLS, use:
#   SITE_ADDRESS=:80
# NOTE: the access cookie is Secure in production, so the login only works over
# HTTPS — use a real domain for anything beyond local testing.
SITE_ADDRESS=legiapp.example.org

# Shared access code your team enters to view the site (one code for everyone).
# Make it long and unguessable.
ACCESS_CODE=change-me-to-a-long-random-phrase

# Browser origin for CORS — set to your https:// site URL. Harmless if left as-is
# since the SPA and API are same-origin behind Caddy.
WEB_ORIGIN=https://legiapp.example.org

# Postgres password for the bundled database container.
POSTGRES_PASSWORD=change-me-to-a-strong-db-password
